{
  "manifest_version": 3,
  "name": "Gemini Video Automator",
  "version": "2.0.0",
  "description": "Automatiza geração sequencial de vídeos no Gemini Enterprise",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "downloads",
    "storage",
    "clipboardWrite",
    "sidePanel"
  ],
  "host_permissions": [
    "https://business.gemini.google.com/*"
  ],
  "action": {
    "default_title": "Gemini Video Automator"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://business.gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
