{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/Administrador.LAURAFERREIRA/Downloads/refresh_gdrive_token.js\" 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "Renovando token do Google Drive..."
          },
          {
            "type": "command",
            "command": "cd \"C:/Users/Administrador.LAURAFERREIRA/Downloads/Claude (Host)\" && git add . && git diff --cached --quiet || git commit -m \"Auto-update: $(date '+%Y-%m-%d %H:%M:%S')\" && git push origin master 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Sincronizando com GitHub..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"C:/Users/Administrador.LAURAFERREIRA/.claude/statusline.sh\""
  },
